<?xml version="1.0" encoding="UTF-8"?>
<!--
  SpotBugs exclusion filter for JavaFX projects.
  Excludes common false positives in JavaFX desktop applications.
-->
<FindBugsFilter xmlns="https://github.com/spotbugs/filter/3.0.0"
                xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0
                                     https://raw.githubusercontent.com/spotbugs/spotbugs/master/spotbugs/etc/findbugsfilter.xsd">

    <!-- Exclude FXML controller fields injected by FXMLLoader (not set by constructor) -->
    <Match>
        <Bug pattern="UWF_FIELD_NOT_INITIALIZED_IN_CONSTRUCTOR"/>
        <Class annot="javafx.fxml.FXML"/>
    </Match>

    <!-- Exclude JavaFX Property fields — they use lazy initialization pattern -->
    <Match>
        <Bug pattern="UWF_NULL_FIELD"/>
        <Field type="javafx.beans.property.*Property"/>
    </Match>

    <!-- Exclude test classes from certain checks -->
    <Match>
        <Class name="~.*Test"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Class name="~.*Test"/>
        <Bug pattern="SIC_INNER_SHOULD_BE_STATIC_ANON"/>
    </Match>

    <!-- Exclude generated code -->
    <Match>
        <Class name="~.*\.(generated|auto)\..*"/>
    </Match>

    <!-- Exclude Application class — JavaFX lifecycle methods may appear unused -->
    <Match>
        <Class name="~.*Application"/>
        <Bug pattern="UPM_UNCALLED_PUBLIC_METHOD"/>
    </Match>

    <!-- Allow @FXML-annotated methods to appear uncalled (invoked via reflection) -->
    <Match>
        <Bug pattern="UPM_UNCALLED_PUBLIC_METHOD"/>
        <Method annot="javafx.fxml.FXML"/>
    </Match>
</FindBugsFilter>
