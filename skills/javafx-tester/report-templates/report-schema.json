{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://javafx-skill.dev/schemas/test-report.json",
  "title": "JavaFX Test Report (JSON)",
  "description": "Machine-readable test report schema for javafx-tester. Mirrors the Markdown test-report.md template. Used by javafx-developer Fix Consumption, CI/CD quality gates, and IDE plugins.",
  "type": "object",
  "required": [
    "report_type",
    "report_version",
    "generated_at",
    "project",
    "test_mode",
    "round",
    "summary",
    "issues",
    "fix_handoffs",
    "loop_state"
  ],
  "properties": {
    "report_type": {
      "type": "string",
      "const": "test",
      "description": "Always 'test' to distinguish from review and verification reports"
    },
    "report_version": {
      "type": "string",
      "const": "1.2",
      "description": "Report format version. Incremented when the report schema structure changes (e.g., adding Track D visual regression in v1.2). This tracks the report format, not the SKILL.md version, though they are kept in sync."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "project": { "type": "string" },
    "test_mode": {
      "type": "string",
      "enum": ["full", "targeted", "selective"],
      "description": "full = all 4 dimensions (executed in parallel by default); targeted = Round 2+ fix-affected only; selective = user-requested subset. Execution mode (parallel vs sequential fallback) is recorded in parallel_execution field"
    },
    "round": {
      "type": "integer",
      "minimum": 1
    },
    "summary": {
      "type": "object",
      "required": [
        "conclusion",
        "pass_rate",
        "total_issues",
        "critical_count",
        "major_count",
        "minor_count",
        "info_count",
        "dimensions"
      ],
      "properties": {
        "conclusion": {
          "type": "string",
          "enum": ["Pass", "Conditional Pass", "Fail"]
        },
        "pass_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "total_issues": { "type": "integer", "minimum": 0 },
        "critical_count": { "type": "integer", "minimum": 0 },
        "major_count": { "type": "integer", "minimum": 0 },
        "minor_count": { "type": "integer", "minimum": 0 },
        "info_count": { "type": "integer", "minimum": 0 },
        "dimensions": {
          "type": "object",
          "properties": {
            "performance": {
              "type": "object",
              "required": ["conclusion", "issues"],
              "properties": {
                "conclusion": { "type": "string", "enum": ["Pass", "Conditional Pass", "Fail", "Skipped"] },
                "issues": { "type": "integer", "minimum": 0 },
                "duration_ms": { "type": "integer", "minimum": 0, "description": "Wall-clock duration of this parallel track" },
                "status": { "type": "string", "enum": ["completed", "skipped", "timeout", "error"], "description": "Track execution status" }
              }
            },
            "security": {
              "type": "object",
              "required": ["conclusion", "issues"],
              "properties": {
                "conclusion": { "type": "string", "enum": ["Pass", "Conditional Pass", "Fail", "Skipped"] },
                "issues": { "type": "integer", "minimum": 0 },
                "duration_ms": { "type": "integer", "minimum": 0, "description": "Wall-clock duration of this parallel track" },
                "status": { "type": "string", "enum": ["completed", "skipped", "timeout", "error"], "description": "Track execution status" }
              }
            },
            "accessibility": {
              "type": "object",
              "required": ["conclusion", "issues"],
              "properties": {
                "conclusion": { "type": "string", "enum": ["Pass", "Conditional Pass", "Fail", "Skipped"] },
                "issues": { "type": "integer", "minimum": 0 },
                "duration_ms": { "type": "integer", "minimum": 0, "description": "Wall-clock duration of this parallel track" },
                "status": { "type": "string", "enum": ["completed", "skipped", "timeout", "error"], "description": "Track execution status" }
              }
            },
            "visual_regression": {
              "type": "object",
              "required": ["conclusion", "issues"],
              "properties": {
                "conclusion": { "type": "string", "enum": ["Pass", "Conditional Pass", "Fail", "Skipped"] },
                "issues": { "type": "integer", "minimum": 0 },
                "snapshots_compared": { "type": "integer", "minimum": 0 },
                "snapshots_passed": { "type": "integer", "minimum": 0 },
                "snapshots_regressed": { "type": "integer", "minimum": 0 },
                "snapshots_baseline_created": { "type": "integer", "minimum": 0 },
                "duration_ms": { "type": "integer", "minimum": 0, "description": "Wall-clock duration of this parallel track" },
                "status": { "type": "string", "enum": ["completed", "skipped", "timeout", "error"], "description": "Track execution status" }
              }
            }
          }
        }
      }
    },
    "performance_metrics": {
      "type": "object",
      "description": "Performance measurement results. Omitted if performance testing was skipped.",
      "properties": {
        "startup_time": {
          "type": "object",
          "required": ["cold_startup_median_ms", "result"],
          "properties": {
            "cold_startup_median_ms": { "type": "number", "minimum": 0 },
            "warm_startup_median_ms": { "type": "number", "minimum": 0 },
            "jvm_start_ms": { "type": "number", "minimum": 0 },
            "javafx_init_ms": { "type": "number", "minimum": 0 },
            "fxml_load_ms": { "type": "number", "minimum": 0 },
            "result": { "type": "string", "enum": ["Pass", "Minor", "Major", "Critical"] }
          }
        },
        "ui_response_latency": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["interaction", "response_ms", "result"],
            "properties": {
              "interaction": { "type": "string" },
              "response_ms": { "type": "number", "minimum": 0 },
              "result": { "type": "string", "enum": ["Pass", "Minor", "Major", "Critical"] }
            }
          }
        },
        "memory_footprint": {
          "type": "object",
          "required": ["baseline_mb", "net_growth_mb", "result"],
          "properties": {
            "baseline_mb": { "type": "number", "minimum": 0 },
            "after_usage_mb": { "type": "number", "minimum": 0 },
            "net_growth_mb": { "type": "number" },
            "full_gc_per_min": { "type": "number", "minimum": 0 },
            "result": { "type": "string", "enum": ["Pass", "Minor", "Major", "Critical"] }
          }
        }
      }
    },
    "security_findings": {
      "type": "object",
      "description": "Security testing results. Omitted if security testing was skipped.",
      "properties": {
        "dependency_scan": {
          "type": "object",
          "required": ["total_cves", "result"],
          "properties": {
            "total_cves": { "type": "integer", "minimum": 0 },
            "critical_cves": { "type": "integer", "minimum": 0 },
            "high_cves": { "type": "integer", "minimum": 0 },
            "medium_cves": { "type": "integer", "minimum": 0 },
            "low_cves": { "type": "integer", "minimum": 0 },
            "suppression_file": { "type": "string", "enum": ["valid", "invalid", "not_found"] },
            "scan_tool": { "type": "string" },
            "cves": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["cve_id", "cvss_score", "severity", "affected_dependency"],
                "properties": {
                  "cve_id": { "type": "string" },
                  "cvss_score": { "type": "number", "minimum": 0, "maximum": 10 },
                  "severity": { "type": "string", "enum": ["Critical", "Major", "Minor"] },
                  "affected_dependency": { "type": "string" },
                  "description": { "type": "string" },
                  "remediation": { "type": "string" }
                }
              }
            },
            "result": { "type": "string", "enum": ["Pass", "Major", "Critical"] }
          }
        },
        "fuzz_testing": {
          "type": "object",
          "required": ["total_fields_tested", "total_failures", "result"],
          "properties": {
            "total_fields_tested": { "type": "integer", "minimum": 0 },
            "total_patterns": { "type": "integer", "minimum": 0 },
            "total_failures": { "type": "integer", "minimum": 0 },
            "results": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["field", "pattern", "result"],
                "properties": {
                  "field": { "type": "string" },
                  "pattern": { "type": "string" },
                  "result": { "type": "string", "enum": ["Pass", "Fail"] },
                  "exception": { "type": "string" },
                  "severity": { "type": "string", "enum": ["Pass", "Minor", "Major", "Critical"] }
                }
              }
            },
            "result": { "type": "string", "enum": ["Pass", "Major", "Critical"] }
          }
        },
        "webview_security": {
          "type": "object",
          "required": ["applicable", "result"],
          "properties": {
            "applicable": { "type": "boolean", "description": "false if project does not use WebView" },
            "javascript_access": { "type": "string", "enum": ["Pass", "Major", "Critical", "N/A"] },
            "content_validation": { "type": "string", "enum": ["Pass", "Major", "Critical", "N/A"] },
            "cors_restrictions": { "type": "string", "enum": ["Pass", "Major", "Critical", "N/A"] },
            "result": { "type": "string", "enum": ["Pass", "Major", "Critical", "Skipped"] }
          }
        }
      }
    },
    "accessibility_results": {
      "type": "object",
      "description": "Accessibility testing results. Omitted if accessibility testing was skipped.",
      "properties": {
        "keyboard_navigation": {
          "type": "object",
          "required": ["tab_order", "focus_visibility", "keyboard_shortcuts", "result"],
          "properties": {
            "tab_order": { "type": "string", "enum": ["Pass", "Minor", "Major", "Critical"] },
            "controls_reachable": { "type": "string", "description": "e.g. '15/15'" },
            "focus_visibility": { "type": "string", "enum": ["Pass", "Minor", "Major"] },
            "keyboard_shortcuts": { "type": "string", "enum": ["Pass", "Minor", "Major"] },
            "result": { "type": "string", "enum": ["Pass", "Minor", "Major", "Critical"] }
          }
        },
        "color_contrast": {
          "type": "object",
          "required": ["total_checked", "total_passing", "result"],
          "properties": {
            "total_checked": { "type": "integer", "minimum": 0 },
            "total_passing": { "type": "integer", "minimum": 0 },
            "failures": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["element", "foreground", "background", "ratio", "threshold", "result"],
                "properties": {
                  "element": { "type": "string" },
                  "foreground": { "type": "string" },
                  "background": { "type": "string" },
                  "ratio": { "type": "number", "minimum": 1 },
                  "threshold": { "type": "number" },
                  "result": { "type": "string", "enum": ["Minor", "Major", "Critical"] }
                }
              }
            },
            "result": { "type": "string", "enum": ["Pass", "Minor", "Major", "Critical"] }
          }
        },
        "screen_reader": {
          "type": "object",
          "required": ["accessible_text_coverage", "result"],
          "properties": {
            "accessible_text_coverage": { "type": "number", "minimum": 0, "maximum": 1 },
            "accessible_help_coverage": { "type": "number", "minimum": 0, "maximum": 1 },
            "image_alt_text_coverage": { "type": "number", "minimum": 0, "maximum": 1 },
            "live_region_support": { "type": "string", "enum": ["Pass", "Minor", "Major"] },
            "result": { "type": "string", "enum": ["Pass", "Minor", "Major"] }
          }
        }
      }
    },
    "visual_regression_results": {
      "type": "object",
      "description": "Visual regression testing results. Omitted if visual regression testing was skipped.",
      "required": ["baseline_mode", "total_snapshots", "result"],
      "properties": {
        "baseline_mode": {
          "type": "string",
          "enum": ["compare", "create", "update"],
          "description": "compare = normal regression check; create = first run, no baselines exist; update = vr_update_baselines enabled"
        },
        "total_snapshots": { "type": "integer", "minimum": 0 },
        "snapshots_passed": { "type": "integer", "minimum": 0 },
        "snapshots_regressed": { "type": "integer", "minimum": 0 },
        "snapshots_baseline_created": { "type": "integer", "minimum": 0 },
        "pixel_tolerance": { "type": "integer", "minimum": 0, "maximum": 255, "description": "Per-channel RGB tolerance used for comparison" },
        "diff_threshold": { "type": "number", "minimum": 0, "maximum": 1, "description": "Diff ratio threshold (e.g., 0.02 for 2%)" },
        "rendering_mode": { "type": "string", "enum": ["monocle", "glass", "native"], "description": "Rendering pipeline used for screenshot capture" },
        "snapshot_results": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["snapshot_id", "view", "state", "diff_ratio", "result"],
            "properties": {
              "snapshot_id": { "type": "string", "description": "e.g., 'main-view/default'" },
              "view": { "type": "string" },
              "state": { "type": "string" },
              "diff_ratio": { "type": "number", "minimum": 0, "maximum": 1, "description": "0.0 = identical, 1.0 = completely different" },
              "diff_pixels": { "type": "integer", "minimum": 0 },
              "comparable_pixels": { "type": "integer", "minimum": 0 },
              "diff_image_path": { "type": "string", "description": "Path to diff visualization image (relative to project root)" },
              "baseline_path": { "type": "string", "description": "Path to baseline PNG" },
              "result": { "type": "string", "enum": ["Pass", "Minor", "Major", "Critical", "Baseline Created", "Baseline Updated"] },
              "ignore_regions_count": { "type": "integer", "minimum": 0 }
            }
          }
        },
        "result": { "type": "string", "enum": ["Pass", "Minor", "Major", "Critical", "Skipped"] }
      }
    },
    "parallel_execution": {
      "type": "object",
      "description": "Parallel execution metadata for the four testing tracks. Present when tester runs in parallel mode (default).",
      "required": ["execution_mode", "tracks"],
      "properties": {
        "execution_mode": {
          "type": "string",
          "enum": ["parallel", "sequential"],
          "description": "parallel = all 4 tracks dispatched simultaneously (default); sequential = fallback for resource-constrained environments (.loop-config.json tester_parallel: false)"
        },
        "wall_clock_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Total wall-clock time from first track start to last track completion. In parallel mode, this is less than the sum of individual track durations."
        },
        "sum_of_track_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Sum of individual track durations. In parallel mode, wall_clock_ms < sum_of_track_ms (speedup). In sequential mode, wall_clock_ms ≈ sum_of_track_ms."
        },
        "speedup_factor": {
          "type": "number",
          "minimum": 1,
          "description": "sum_of_track_ms / wall_clock_ms. ~4.0 for ideal 4-way parallelism; 1.0 for sequential."
        },
        "tracks": {
          "type": "object",
          "required": ["performance", "security", "accessibility", "visual_regression"],
          "properties": {
            "performance": {
              "type": "object",
              "required": ["start_time", "end_time", "duration_ms", "conclusion", "status"],
              "properties": {
                "start_time": { "type": "string", "format": "date-time" },
                "end_time": { "type": "string", "format": "date-time" },
                "duration_ms": { "type": "integer", "minimum": 0 },
                "conclusion": { "type": "string", "enum": ["Pass", "Conditional Pass", "Fail", "Skipped"] },
                "status": { "type": "string", "enum": ["completed", "skipped", "timeout", "error"] },
                "error_message": { "type": "string", "description": "Present only when status is timeout or error" }
              }
            },
            "security": {
              "type": "object",
              "required": ["start_time", "end_time", "duration_ms", "conclusion", "status"],
              "properties": {
                "start_time": { "type": "string", "format": "date-time" },
                "end_time": { "type": "string", "format": "date-time" },
                "duration_ms": { "type": "integer", "minimum": 0 },
                "conclusion": { "type": "string", "enum": ["Pass", "Conditional Pass", "Fail", "Skipped"] },
                "status": { "type": "string", "enum": ["completed", "skipped", "timeout", "error"] },
                "error_message": { "type": "string", "description": "Present only when status is timeout or error" }
              }
            },
            "accessibility": {
              "type": "object",
              "required": ["start_time", "end_time", "duration_ms", "conclusion", "status"],
              "properties": {
                "start_time": { "type": "string", "format": "date-time" },
                "end_time": { "type": "string", "format": "date-time" },
                "duration_ms": { "type": "integer", "minimum": 0 },
                "conclusion": { "type": "string", "enum": ["Pass", "Conditional Pass", "Fail", "Skipped"] },
                "status": { "type": "string", "enum": ["completed", "skipped", "timeout", "error"] },
                "error_message": { "type": "string", "description": "Present only when status is timeout or error" }
              }
            },
            "visual_regression": {
              "type": "object",
              "required": ["start_time", "end_time", "duration_ms", "conclusion", "status"],
              "properties": {
                "start_time": { "type": "string", "format": "date-time" },
                "end_time": { "type": "string", "format": "date-time" },
                "duration_ms": { "type": "integer", "minimum": 0 },
                "conclusion": { "type": "string", "enum": ["Pass", "Conditional Pass", "Fail", "Skipped"] },
                "status": { "type": "string", "enum": ["completed", "skipped", "timeout", "error"] },
                "error_message": { "type": "string", "description": "Present only when status is timeout or error" }
              }
            }
          }
        }
      }
    },
    "issues": {
      "type": "array",
      "description": "List of all issues found, sorted by severity descending, then by dimension (Performance → Security → Accessibility)",
      "items": {
        "type": "object",
        "required": ["id", "severity", "dimension", "title", "description", "rule_reference"],
        "properties": {
          "id": { "type": "integer", "minimum": 1 },
          "severity": { "type": "string", "enum": ["Critical", "Major", "Minor", "Info"] },
          "dimension": {
            "type": "string",
            "enum": ["Performance Testing", "Security Testing", "Accessibility Testing", "Visual Regression Testing"]
          },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "file": { "type": "string" },
          "lines": { "type": "string", "pattern": "^\\d+(-\\d+)?$" },
          "rule_reference": { "type": "string" },
          "problematic_code": { "type": "string" },
          "root_cause_analysis": { "type": "string" },
          "corrected_example": { "type": "string" },
          "escalation_note": { "type": "string" },
          "fix_handoff": {
            "type": "object",
            "required": ["target_file", "target_lines", "fix_type", "fix_priority", "code_fingerprint", "anchor_pattern", "ast_node_signature"],
            "properties": {
              "target_file": { "type": "string" },
              "target_lines": { "type": "string", "pattern": "^\\d+(-\\d+)?$" },
              "fix_type": { "type": "string", "enum": ["replace", "insert", "delete"] },
              "fix_priority": { "type": "integer", "minimum": 1 },
              "code_fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "anchor_pattern": { "type": "string" },
              "ast_node_signature": { "type": ["string", "null"], "description": "AST-level anchor: fully qualified method/field/class signature. Null for non-Java files." }
            }
          }
        }
      }
    },
    "fix_handoffs": {
      "type": "array",
      "description": "Standalone array of all fix handoffs, sorted by fix_priority ascending. Fully consistent with javafx-code-reviewer and javafx-runner.",
      "items": {
        "type": "object",
        "required": ["target_file", "target_lines", "fix_type", "fix_priority", "code_fingerprint", "anchor_pattern", "ast_node_signature", "issue_id", "severity"],
        "properties": {
          "target_file": { "type": "string" },
          "target_lines": { "type": "string", "pattern": "^\\d+(-\\d+)?$" },
          "fix_type": { "type": "string", "enum": ["replace", "insert", "delete"] },
          "fix_priority": { "type": "integer", "minimum": 1 },
          "code_fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "anchor_pattern": { "type": "string" },
          "ast_node_signature": { "type": ["string", "null"], "description": "AST-level anchor: fully qualified method/field/class signature. Null for non-Java files." },
          "corrected_example": { "type": "string" },
          "issue_id": { "type": "integer", "minimum": 1 },
          "severity": { "type": "string", "enum": ["Critical", "Major", "Minor", "Info"] }
        }
      }
    },
    "loop_state": {
      "type": "object",
      "required": ["current_round", "convergence_trend", "next_action"],
      "properties": {
        "current_round": { "type": "integer", "minimum": 1 },
        "convergence_trend": {
          "type": "array",
          "items": { "type": "integer" }
        },
        "next_action": {
          "type": "string",
          "enum": ["fixing", "incremental_test", "passed", "paused"]
        },
        "tester_perf_result": {
          "type": ["object", "null"],
          "description": "Track A (Performance) isolated result. Written only by the performance track. Null if track not executed.",
          "properties": {
            "conclusion": { "type": "string", "enum": ["Pass", "Conditional Pass", "Fail", "Skipped"] },
            "critical": { "type": "integer", "minimum": 0 },
            "major": { "type": "integer", "minimum": 0 },
            "minor": { "type": "integer", "minimum": 0 },
            "info": { "type": "integer", "minimum": 0 },
            "fix_handoff_count": { "type": "integer", "minimum": 0 },
            "duration_ms": { "type": "integer", "minimum": 0 }
          }
        },
        "tester_sec_result": {
          "type": ["object", "null"],
          "description": "Track B (Security) isolated result. Written only by the security track. Null if track not executed.",
          "properties": {
            "conclusion": { "type": "string", "enum": ["Pass", "Conditional Pass", "Fail", "Skipped"] },
            "critical": { "type": "integer", "minimum": 0 },
            "major": { "type": "integer", "minimum": 0 },
            "minor": { "type": "integer", "minimum": 0 },
            "info": { "type": "integer", "minimum": 0 },
            "fix_handoff_count": { "type": "integer", "minimum": 0 },
            "duration_ms": { "type": "integer", "minimum": 0 }
          }
        },
        "tester_a11y_result": {
          "type": ["object", "null"],
          "description": "Track C (Accessibility) isolated result. Written only by the accessibility track. Null if track not executed.",
          "properties": {
            "conclusion": { "type": "string", "enum": ["Pass", "Conditional Pass", "Fail", "Skipped"] },
            "critical": { "type": "integer", "minimum": 0 },
            "major": { "type": "integer", "minimum": 0 },
            "minor": { "type": "integer", "minimum": 0 },
            "info": { "type": "integer", "minimum": 0 },
            "fix_handoff_count": { "type": "integer", "minimum": 0 },
            "duration_ms": { "type": "integer", "minimum": 0 }
          }
        },
        "tester_vr_result": {
          "type": ["object", "null"],
          "description": "Track D (Visual Regression) isolated result. Written only by the visual regression track. Null if track not executed or visual_regression config is false.",
          "properties": {
            "conclusion": { "type": "string", "enum": ["Pass", "Conditional Pass", "Fail", "Skipped"] },
            "critical": { "type": "integer", "minimum": 0 },
            "major": { "type": "integer", "minimum": 0 },
            "minor": { "type": "integer", "minimum": 0 },
            "info": { "type": "integer", "minimum": 0 },
            "fix_handoff_count": { "type": "integer", "minimum": 0 },
            "duration_ms": { "type": "integer", "minimum": 0 },
            "snapshots_compared": { "type": "integer", "minimum": 0 },
            "snapshots_passed": { "type": "integer", "minimum": 0 },
            "snapshots_regressed": { "type": "integer", "minimum": 0 },
            "snapshots_baseline_created": { "type": "integer", "minimum": 0 }
          }
        },
        "tester_result": {
          "type": ["object", "null"],
          "description": "Aggregated tester result computed from the four track fields. This is what the Test Gate reads.",
          "properties": {
            "conclusion": { "type": "string", "enum": ["Pass", "Conditional Pass", "Fail"] },
